{
	"name": "@nsis/language-data",
	"version": "0.9.3",
	"description": "Data for contributed NSIS language files in JSON format",
	"type": "module",
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./codepages": {
			"types": "./types/codepages.d.ts",
			"import": "./dist/codepages.mjs",
			"require": "./dist/codepages.cjs"
		},
		"./meta": {
			"types": "./types/meta.d.ts",
			"import": "./dist/meta.mjs",
			"require": "./dist/meta.cjs"
		},
		"./languages": {
			"types": "./types/languages.d.ts",
			"import": "./dist/languages.mjs",
			"require": "./dist/languages.cjs"
		}
	},
	"sideEffects": false,
	"files": [
		"data/",
		"dist/",
		"types/"
	],
	"scripts": {
		"build:code": "tsdown",
		"build:json": "node tools/build.mjs",
		"build": "npm run build:json && npm run build:code",
		"lint": "biome check",
		"prepack": "npm run build",
		"test": "npm run lint"
	},
	"author": "Jan T. Sott",
	"license": "Zlib",
	"repository": {
		"type": "git",
		"url": "https://github.com/NSIS-Dev/language-data.git"
	},
	"keywords": [
		"nsis"
	],
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@idleberg/configs": "^0.4.2",
		"@nsis/mui-language-strings": "^0.3.0",
		"@nsis/nlf": "^0.12.0",
		"@types/node": "^24",
		"globby": "^11.1.0",
		"lint-staged": "^16.1.2",
		"makensis": "^3.0.0",
		"npm-run-all": "^4.1.5",
		"rimraf": "^5.0.10",
		"tsdown": "^0.21.4",
		"tslib": "^2.8.1",
		"typescript": "^5.8.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"lefthook"
		]
	}
}
